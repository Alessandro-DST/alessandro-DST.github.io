---
import ProjectCard from './ProjectCard.astro';
import InfraDiagram from './diagram/InfraDiagram.astro';
---

<section id="projects" aria-labelledby="projects-title">
  <h2 id="projects-title" class="text-2xl font-semibold tracking-tight text-neutral-900">
    Projects
  </h2>
  <div class="mt-6 grid gap-6">
    <ProjectCard
      title="Bella Bri — IT infrastructure"
      blurb="An interactive map of a small-business network: services, segmentation and remote access. Hover a node for details."
      tags={['Networking', 'Self-hosting', 'Security']}
    >
      <InfraDiagram />
    </ProjectCard>
  </div>
</section>
